  "keyFeatures": [
    "Unified interface for multiple bank integrations",
    "CLI tool for checking balances and fetching transactions",
    "Ruby library API for programmatic access",
    "Adapter generator for creating new bank integrations",
    "Support for accounts, cards, loans, and investments",
    "CSV and JSON export capabilities",
    "Web scraping and API reverse engineering support"
  ],
  "publicApiSurface": [
    "Bankscrap::Bank - Base class for bank adapters",
    "Bankscrap::Account - Bank account representation",
    "Bankscrap::Transaction - Transaction model",
    "Bankscrap::Card - Credit card model",
    "Bankscrap::Loan - Loan model",
    "Bankscrap::Investment - Investment model",
    "BankScrap::Exporter::Csv - CSV exporter",
    "BankScrap::Exporter::Json - JSON exporter",
    "bankscrap balance - CLI command to fetch account balances",
    "bankscrap transactions - CLI command to fetch transactions",
    "bankscrap cards - CLI command to fetch credit cards",
    "bankscrap loans - CLI command to fetch loans",
    "bankscrap generate_adapter - CLI command to scaffold new adapters"
  ]
}
